{
  "name": "audit-garantie-vw-monorepo",
  "version": "1.0.0",
  "description": "Application de gestion d'audits de garantie VW - Optimisée pour Hostinger",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd client && npm start\"",
    "build": "cd client && npm install && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2"
  },
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "keywords": [
    "volkswagen",
    "audit",
    "garantie",
    "dossier",
    "ocr"
  ],
  "author": "Holert Fabien",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "multer": "^1.4.4-lts.1",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  }
}
