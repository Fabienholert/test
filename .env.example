# --- Frontend (racine du repo, build Vite / Netlify) ---
# Prod Netlify : ne pas définir VITE_API_URL — le front utilise /api (proxy netlify.toml → Render).
# Sur Netlify (Environment variables), supprimez VITE_API_URL si elle pointe vers onrender.com.
#
# Dev uniquement :
# VITE_API_URL=http://localhost:5001/api

# --- Backend (dossier backend/, ou variables du service Render) ---
# Copier backend/.env.example vers backend/.env pour le local

FRONTEND_URL=https://testgarantie.netlify.app
MONGODB_URI=
JWT_SECRET=
GMAIL_USER=
GMAIL_PASSWORD=
# Ancien nom (CRA) — non utilisé par Vite
# REACT_APP_API_URL=http://localhost:5000/api

